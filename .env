# LiveKit Credentials
LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud
LIVEKIT_API_KEY=ADD_YOUR_LIVEKIT_API_KEY
LIVEKIT_API_SECRET=ADD_YOUR_LIVEKIT_API_SECRET

# Deepgram STT & TTS
DEEPGRAM_API_KEY=ADD_YOUR_DEEPGRAM_API_KEY

# Google Gemini API (via Google AI Studio or Vertex AI)
GOOGLE_API_KEY=ADD_YOUR_GOOGLE_API_KEY

# Optional: OpenAI/Groq/Resemble if needed
OPENAI_API_KEY=ADD_YOUR_OPENAI_API_KEY
OPENAI_API_BASE=https://openrouter.ai/api/v1  # Optional if using OpenRouter

GROQ_API_KEY=ADD_YOUR_GROQ_API_KEY
RESEMBLE_API_KEY=ADD_YOUR_RESEMBLE_API_KEY
